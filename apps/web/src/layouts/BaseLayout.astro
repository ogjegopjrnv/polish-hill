---
import "@/styles/global.css";
import SiteHeader from "@components/layout/SiteHeader.astro";
import SiteFooter from "@components/layout/SiteFooter.astro";
import ModalForm from "@components/form/ModalForm.astro";
import CottageModal from "@components/form/CottageModal.astro";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = "Котеджне містечко Polish Hill — 17 котеджів на Оболоні, Київ. Від $1000/м². Безпроцентна розстрочка 1.5 року.",
  ogImage = "/og-default.png",
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const locale = Astro.currentLocale ?? "uk";
---

<!doctype html>
<html lang={locale} data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | Polish Hill</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl.href} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={`${title} | Polish Hill`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site).href} />
    <meta property="og:url" content={canonicalUrl.href} />
    <meta property="og:locale" content={locale === "uk" ? "uk_UA" : "en_US"} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | Polish Hill`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site).href} />

    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <!-- Analytics -->
    <script>
      import { initMetaPixel, initGtag } from "@lib/analytics/analytics";
      const pixelId = import.meta.env.PUBLIC_META_PIXEL_ID;
      if (pixelId) initMetaPixel(pixelId);
      const gaId = import.meta.env.PUBLIC_GA4_ID;
      if (gaId) initGtag(gaId);
    </script>

    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "WebSite",
        name: "Polish Hill",
        url: "https://ph.kiev.ua",
        description: "Котеджне містечко Polish Hill — преміум таунхауси на Оболоні, Київ",
        inLanguage: locale === "uk" ? "uk-UA" : "en-US",
      })}
    />
  </head>
  <body class="flex min-h-dvh flex-col overflow-x-hidden bg-[var(--ph-bg)] text-[var(--ph-ink)]">
    <a href="#main" class="skip-link">Перейти до контенту</a>
    <SiteHeader />
    <main id="main" class="flex-1">
      <slot />
    </main>
    <SiteFooter />
    <ModalForm />
    <CottageModal />

    <!-- UTM capture -->
    <script>
      import { captureUtmParams } from "@lib/analytics/utm";
      captureUtmParams();
    </script>

    <!-- Phone click tracking -->
    <script>
      import { trackContact, trackCTAClick, trackScheduleVisit } from "@lib/analytics/analytics";
      document.querySelectorAll('a[href^="tel:"]').forEach((link) => {
        link.addEventListener("click", () => trackContact("phone"));
      });
      document.querySelectorAll("[data-modal-trigger]").forEach((btn) => {
        btn.addEventListener("click", () => {
          const section = btn.closest("section")?.id || btn.closest("header")?.id || "unknown";
          trackCTAClick("book_tour", section);
          trackScheduleVisit();
        });
      });
    </script>

    <!-- Section visibility tracking -->
    <script>
      import { trackSectionView } from "@lib/analytics/analytics";
      const trackedSections = new Set<string>();
      const sections = document.querySelectorAll("section[id]");
      if (sections.length && "IntersectionObserver" in window) {
        const sectionObserver = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              const id = entry.target.id;
              if (!trackedSections.has(id)) {
                trackedSections.add(id);
                trackSectionView(id);
              }
            }
          });
        }, { threshold: 0.3 });
        sections.forEach((s) => sectionObserver.observe(s));
      }
    </script>

    <!-- Scroll reveal observer -->
    <script>
      // Immediately reveal elements that are already in viewport
      const reveals = document.querySelectorAll(".reveal");

      if ("IntersectionObserver" in window) {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("visible");
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.08, rootMargin: "0px 0px -40px 0px" }
        );
        reveals.forEach((el) => observer.observe(el));
      } else {
        // Fallback: show everything
        reveals.forEach((el) => el.classList.add("visible"));
      }
    </script>
  </body>
</html>
