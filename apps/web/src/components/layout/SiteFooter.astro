---
import { t } from "@lib/i18n/translations";
import type { Locale } from "@lib/i18n/translations";

const locale = (Astro.currentLocale ?? "uk") as Locale;
const i = t(locale);

const navLinks = [
  { label: i.nav.lots, href: "#cottages" },
  { label: i.nav.masterPlan, href: "#masterplan" },
  { label: i.nav.location, href: "#location" },
  { label: i.nav.finance, href: "#finance" },
  { label: i.nav.about, href: "#about" },
  { label: i.nav.contact, href: "#contact" },
];
---

<footer class="border-t border-[var(--ph-border)] bg-[var(--ph-bg-alt)]">
  <div class="container-ph pt-16 pb-8">
    <div class="grid grid-cols-1 gap-12 md:grid-cols-2 lg:grid-cols-4">
      <!-- Brand -->
      <div class="lg:col-span-1">
        <a href="/" class="flex items-center gap-2.5">
          <img src="/images/client/ph-6.jpg" alt="Polish Hill" class="h-8 w-8 rounded-[var(--ph-radius-sm)] object-cover" />
          <span class="text-lg font-semibold tracking-tight" style="font-family: var(--font-display);">Polish Hill</span>
        </a>
        <p class="mt-4 max-w-xs text-[0.8125rem] leading-relaxed text-[var(--ph-ink-muted)]">
          {locale === "uk"
            ? "Преміум котеджне містечко на Оболоні. Ліс, озеро, 15 хвилин до центру Києва."
            : "Premium cottage community in Obolon. Forest, lake, 15 min to Kyiv center."}
        </p>
      </div>

      <!-- Nav -->
      <div>
        <h4 class="mb-4 text-[0.6875rem] font-semibold uppercase tracking-[0.15em] text-[var(--ph-ink-muted)]">
          {i.footer.navigation}
        </h4>
        <ul class="flex flex-col gap-2.5" role="list">
          {navLinks.map(({ label, href }) => (
            <li>
              <a href={href} class="text-[0.8125rem] text-[var(--ph-ink-soft)] transition-colors hover:text-[var(--ph-forest)]">
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contacts -->
      <div
        itemscope
        itemtype="https://schema.org/Organization"
      >
        <h4 class="mb-4 text-[0.6875rem] font-semibold uppercase tracking-[0.15em] text-[var(--ph-ink-muted)]">
          {i.footer.contacts}
        </h4>
        <div class="flex flex-col gap-2.5" itemprop="address" itemscope itemtype="https://schema.org/PostalAddress">
          <span class="text-[0.8125rem] text-[var(--ph-ink-soft)]" itemprop="streetAddress">
            вул. Богатирська, 30а
          </span>
          <span class="text-[0.8125rem] text-[var(--ph-ink-soft)]">
            <span itemprop="addressLocality">Київ</span>, <span itemprop="addressRegion">Оболонь</span>
          </span>
          <a href="tel:+380674406070" class="text-[0.8125rem] font-medium text-[var(--ph-ink)] hover:text-[var(--ph-forest)]" itemprop="telephone">
            +380 67 440 60 70
          </a>
          <a href="tel:+380507141478" class="text-[0.8125rem] font-medium text-[var(--ph-ink)] hover:text-[var(--ph-forest)]" itemprop="telephone">
            +380 50 714 14 78
          </a>
          <a href="mailto:phkiev2025@gmail.com" class="text-[0.8125rem] text-[var(--ph-ink-soft)] hover:text-[var(--ph-forest)]" itemprop="email">
            phkiev2025@gmail.com
          </a>
          <p class="text-[0.75rem] text-[var(--ph-ink-muted)]">{i.footer.schedule}</p>
        </div>
      </div>

      <!-- Social -->
      <div>
        <h4 class="mb-4 text-[0.6875rem] font-semibold uppercase tracking-[0.15em] text-[var(--ph-ink-muted)]">
          {i.footer.social}
        </h4>
        <div class="flex gap-2.5">
          {[
            { label: "Telegram", d: "M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.479.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z" },
            { label: "Instagram", d: "M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z" },
            { label: "Facebook", d: "M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" },
          ].map(({ label, d }) => (
            <a
              href="#"
              aria-label={label}
              class="flex h-10 w-10 items-center justify-center rounded-[var(--ph-radius-md)] bg-[var(--ph-surface)] text-[var(--ph-ink-muted)] shadow-[var(--ph-shadow-sm)] transition-all duration-200 hover:text-[var(--ph-forest)] hover:shadow-[var(--ph-shadow-md)]"
            >
              <svg class="h-[18px] w-[18px]" viewBox="0 0 24 24" fill="currentColor">
                <path d={d} />
              </svg>
            </a>
          ))}
        </div>

        <div class="mt-6">
          <a href="/privacy" class="text-[0.75rem] text-[var(--ph-ink-muted)] hover:text-[var(--ph-forest)]">
            {i.footer.privacy}
          </a>
          <span class="mx-2 text-[var(--ph-ink-muted)]">/</span>
          <a href="/terms" class="text-[0.75rem] text-[var(--ph-ink-muted)] hover:text-[var(--ph-forest)]">
            {i.footer.terms}
          </a>
        </div>
      </div>
    </div>

    <!-- Bottom -->
    <div class="mt-12 border-t border-[var(--ph-border)] pt-6">
      <div class="flex flex-col items-center justify-between gap-3 sm:flex-row">
        <p class="text-[0.75rem] text-[var(--ph-ink-muted)]">
          &copy; {new Date().getFullYear()} Polish Hill. ЖК &laquo;Польський куточок&raquo;.
        </p>
        <p class="text-[0.6875rem] text-[var(--ph-ink-muted)]">
          Розроблено <a href="https://osadchiy.org?utm_source=polishhill&utm_medium=referral&utm_campaign=footer" target="_blank" rel="noopener noreferrer" class="underline hover:text-[var(--ph-forest)] transition-colors">Osadchiy Team</a>
        </p>
        <p class="max-w-md text-center text-[0.6875rem] leading-relaxed text-[var(--ph-ink-muted)] sm:text-right">
          {i.footer.disclaimer}
        </p>
      </div>
    </div>
  </div>
</footer>
