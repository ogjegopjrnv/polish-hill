---
import type { Locale } from "@lib/i18n/translations";
import Button from "@components/ui/Button.astro";

const locale = (Astro.currentLocale ?? "uk") as Locale;
---

<section id="contact" class="section relative overflow-hidden bg-[var(--ph-forest-deep)]">
  {/* Decorative elements */}
  <div class="pointer-events-none absolute inset-0 overflow-hidden">
    <div class="absolute -top-1/2 -right-1/4 h-[600px] w-[600px] rounded-full bg-[var(--ph-forest)]/30 blur-[120px]"></div>
    <div class="absolute -bottom-1/2 -left-1/4 h-[400px] w-[400px] rounded-full bg-[var(--ph-stone)]/15 blur-[100px]"></div>
  </div>

  <div class="container-ph relative z-10 text-center">
    <div class="reveal mx-auto max-w-2xl">
      <h2 class="text-white">
        {locale === "uk"
          ? "Готові обрати свій котедж?"
          : "Ready to choose your cottage?"}
      </h2>
      <p class="mt-5 text-[1.125rem] leading-relaxed text-white/75">
        {locale === "uk"
          ? "Запишіться на безкоштовний огляд містечка. Менеджер покаже територію, відповість на питання та допоможе обрати оптимальний варіант."
          : "Book a free tour of the community. Our manager will show the territory, answer questions and help choose the best option."}
      </p>
      <div class="mt-10 flex flex-wrap items-center justify-center gap-4">
        <Button
          as="button"
          variant="white"
          size="lg"
          data-modal-trigger="lead"
        >
          {locale === "uk" ? "Записатись на огляд" : "Book a tour"}
        </Button>
        <a
          href="tel:+380674406070"
          class="flex items-center gap-2 text-[0.9375rem] font-medium text-white/70 transition-colors hover:text-white"
        >
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
          </svg>
          +380 67 440 60 70
        </a>
      </div>
    </div>
  </div>
</section>
