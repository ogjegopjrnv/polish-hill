---
import type { Locale } from "@lib/i18n/translations";
const locale = (Astro.currentLocale ?? "uk") as Locale;
---

<!-- Overlay backdrop -->
<div
  id="modal-overlay"
  class="fixed inset-0 z-[100] hidden bg-black/40 backdrop-blur-sm transition-opacity duration-300"
  aria-hidden="true"
>
  <!-- Modal -->
  <div
    id="modal-container"
    class="flex min-h-full items-center justify-center p-4"
    role="dialog"
    aria-modal="true"
    aria-labelledby="modal-title"
  >
    <div
      id="modal-card"
      class="relative w-full max-w-md translate-y-4 scale-[0.97] rounded-[var(--ph-radius-2xl)] bg-[var(--ph-surface)] p-8 opacity-0 shadow-[var(--ph-shadow-xl)] transition-all duration-[var(--ph-duration-ui)] ease-[var(--ph-ease)] sm:p-10"
    >
      <!-- Close -->
      <button
        id="modal-close"
        class="absolute top-4 right-4 flex h-9 w-9 items-center justify-center rounded-full text-[var(--ph-ink-muted)] transition-colors hover:bg-[var(--ph-ink)]/[0.05] hover:text-[var(--ph-ink)]"
        aria-label="Закрити"
      >
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>

      <div id="modal-intro">
        <!-- Eyebrow -->
        <div class="mb-1">
          <span class="text-[0.75rem] font-semibold uppercase tracking-[0.1em] text-[var(--ph-forest)]">
            {locale === "uk" ? "Зворотний зв\u2019язок" : "Get in touch"}
          </span>
        </div>

        <!-- Title -->
        <h3 id="modal-title" class="text-2xl">
          {locale === "uk" ? "Записатись на огляд" : "Book a tour"}
        </h3>

        <p class="mt-2 text-sm leading-relaxed text-[var(--ph-ink-muted)]">
          {locale === "uk"
            ? "Залиште ваші контакти — менеджер зателефонує протягом 15 хвилин"
            : "Leave your contacts — our manager will call within 15 minutes"}
        </p>
      </div>

      <!-- Form -->
      <form id="modal-lead-form" class="mt-8 flex flex-col gap-4" novalidate>
        <!-- Honeypot -->
        <input type="text" name="website" class="sr-only" tabindex="-1" autocomplete="off" aria-hidden="true" />

        <div>
          <label for="lead-name" class="mb-1.5 block text-[0.8125rem] font-medium text-[var(--ph-ink-soft)]">
            {locale === "uk" ? "Ваше ім\u2019я" : "Your name"}
          </label>
          <input
            type="text"
            id="lead-name"
            name="name"
            required
            autocomplete="given-name"
            class="h-11 w-full rounded-[var(--ph-radius-md)] border border-[var(--ph-border-strong)] bg-[var(--ph-bg)] px-4 text-[0.9375rem] text-[var(--ph-ink)] transition-all duration-200 placeholder:text-[var(--ph-ink-muted)] focus:border-[var(--ph-forest)] focus:ring-2 focus:ring-[var(--ph-forest)]/20 focus:outline-none"
            placeholder={locale === "uk" ? "Олександр" : "John"}
          />
        </div>

        <div>
          <label for="lead-phone" class="mb-1.5 block text-[0.8125rem] font-medium text-[var(--ph-ink-soft)]">
            {locale === "uk" ? "Телефон" : "Phone"}
          </label>
          <input
            type="tel"
            id="lead-phone"
            name="phone"
            required
            autocomplete="tel"
            class="h-11 w-full rounded-[var(--ph-radius-md)] border border-[var(--ph-border-strong)] bg-[var(--ph-bg)] px-4 text-[0.9375rem] text-[var(--ph-ink)] transition-all duration-200 placeholder:text-[var(--ph-ink-muted)] focus:border-[var(--ph-forest)] focus:ring-2 focus:ring-[var(--ph-forest)]/20 focus:outline-none"
            placeholder="+380 __ ___ __ __"
          />
        </div>

        <div>
          <label for="lead-time" class="mb-1.5 block text-[0.8125rem] font-medium text-[var(--ph-ink-soft)]">
            {locale === "uk" ? "Зручний час" : "Preferred time"}
          </label>
          <select
            id="lead-time"
            name="preferred_time"
            class="h-11 w-full cursor-pointer appearance-none rounded-[var(--ph-radius-md)] border border-[var(--ph-border-strong)] bg-[var(--ph-bg)] px-4 text-[0.9375rem] text-[var(--ph-ink)] transition-all duration-200 focus:border-[var(--ph-forest)] focus:ring-2 focus:ring-[var(--ph-forest)]/20 focus:outline-none"
          >
            <option value="any">{locale === "uk" ? "Будь-який" : "Any time"}</option>
            <option value="morning">{locale === "uk" ? "Ранок (9:00–12:00)" : "Morning (9–12)"}</option>
            <option value="afternoon">{locale === "uk" ? "День (12:00–15:00)" : "Afternoon (12–15)"}</option>
            <option value="evening">{locale === "uk" ? "Вечір (15:00–18:00)" : "Evening (15–18)"}</option>
          </select>
        </div>

        <button
          type="submit"
          class="mt-2 flex h-12 w-full items-center justify-center gap-2 rounded-[var(--ph-radius-lg)] bg-[var(--ph-forest)] text-[0.9375rem] font-semibold text-white shadow-[0_1px_2px_rgba(0,0,0,0.1),0_4px_12px_rgba(45,74,58,0.25)] transition-all duration-[var(--ph-duration-ui)] ease-[var(--ph-ease)] hover:bg-[var(--ph-forest-deep)] hover:shadow-[0_4px_16px_rgba(45,74,58,0.35)] active:scale-[0.98]"
        >
          {locale === "uk" ? "Зателефонуйте мені" : "Call me back"}
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </button>
      </form>

      <p id="modal-privacy-note" class="mt-4 text-center text-[0.6875rem] text-[var(--ph-ink-muted)]">
        {locale === "uk"
          ? "Натискаючи, ви погоджуєтесь з політикою конфіденційності"
          : "By clicking, you agree to our privacy policy"}
      </p>

      <!-- Success state (hidden by default) -->
      <div id="modal-success" class="hidden py-8 text-center">
        <div class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-[var(--ph-forest)]/10">
          <svg class="h-8 w-8 text-[var(--ph-forest)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
          </svg>
        </div>
        <p class="text-xl font-semibold text-[var(--ph-forest)]">Дякуємо!</p>
        <p class="mt-2 text-sm text-[var(--ph-ink-muted)]">Менеджер зателефонує вам найближчим часом.</p>
      </div>
    </div>
  </div>
</div>

<script>
  const overlay = document.getElementById("modal-overlay");
  const card = document.getElementById("modal-card");
  const closeBtn = document.getElementById("modal-close");

  function openModal() {
    overlay?.classList.remove("hidden");
    requestAnimationFrame(() => {
      overlay!.style.opacity = "1";
      card!.style.opacity = "1";
      card!.style.transform = "translateY(0) scale(1)";
    });
    document.body.style.overflow = "hidden";
  }

  function closeModal() {
    if (!overlay || !card) return;
    overlay.style.opacity = "0";
    card.style.opacity = "0";
    card.style.transform = "translateY(4px) scale(0.97)";
    setTimeout(() => {
      overlay.classList.add("hidden");
      document.body.style.overflow = "";
    }, 300);
  }

  // Triggers
  document.querySelectorAll("[data-modal-trigger]").forEach((btn) => {
    btn.addEventListener("click", (e) => {
      e.preventDefault();
      openModal();
    });
  });

  closeBtn?.addEventListener("click", closeModal);
  overlay?.addEventListener("click", (e) => {
    if (e.target === overlay || (e.target as HTMLElement).id === "modal-container") closeModal();
  });
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") closeModal();
  });

  // --- Form submission ---
  const form = document.getElementById('modal-lead-form') as HTMLFormElement | null;
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    const originalText = submitBtn.innerHTML;
    submitBtn.disabled = true;
    submitBtn.textContent = '...';

    const fd = new FormData(form);

    // Read UTM from cookies
    const utmParams: Record<string, string> = {};
    for (const key of ['utm_source', 'utm_medium', 'utm_campaign', 'utm_content', 'utm_term']) {
      const match = document.cookie.match(new RegExp(`(?:^|; )${key}=([^;]*)`));
      if (match) utmParams[key] = decodeURIComponent(match[1]);
    }

    const payload = {
      name: fd.get('name'),
      phone: fd.get('phone'),
      preferred_time: fd.get('preferred_time'),
      website: fd.get('website'),
      source_page: window.location.pathname,
      ...utmParams,
    };

    try {
      const res = await fetch('/api/lead', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });

      if (res.ok) {
        if (typeof window.fbq === 'function') window.fbq('track', 'Lead');
        if (typeof window.gtag === 'function') window.gtag('event', 'generate_lead', { currency: 'USD' });

        document.getElementById('modal-intro')!.style.display = 'none';
        form.style.display = 'none';
        document.getElementById('modal-privacy-note')!.style.display = 'none';
        document.getElementById('modal-success')!.classList.remove('hidden');
      } else {
        submitBtn.disabled = false;
        submitBtn.innerHTML = originalText;
      }
    } catch {
      submitBtn.disabled = false;
      submitBtn.innerHTML = originalText;
    }
  });
</script>
