---
import { lots, formatPrice, statusLabelUk } from "@data/lots";
import type { Locale } from "@lib/i18n/translations";

const locale = (Astro.currentLocale ?? "uk") as Locale;

// SVG layout: 2 rows of 8 cottages (Phase I top, Phase II bottom)
// Each cottage is a rect in the SVG
const COL_W = 100;
const COL_GAP = 12;
const ROW_H = 140;
const ROW_GAP = 60;
const PAD = 40;

const phase1 = lots.filter((l) => l.phase === 1);
const phase2 = lots.filter((l) => l.phase === 2);

const svgW = PAD * 2 + phase1.length * COL_W + (phase1.length - 1) * COL_GAP;
const svgH = PAD * 2 + 2 * ROW_H + ROW_GAP + 60; // +60 for labels

function lotColor(status: string) {
  return {
    available: "#4a7c59",
    reserved: "#c8924a",
    sold: "#c4c4c0",
  }[status] ?? "#c4c4c0";
}

function lotFill(status: string) {
  return {
    available: "#e8f5ec",
    reserved: "#fef3e0",
    sold: "#f0efed",
  }[status] ?? "#f0efed";
}
---

<div class="overflow-x-auto rounded-[var(--ph-radius-2xl)] border border-[var(--ph-border)] bg-[var(--ph-surface)] p-4 md:p-8">
  <svg
    viewBox={`0 0 ${svgW} ${svgH}`}
    class="mx-auto w-full max-w-4xl"
    role="img"
    aria-label={locale === "uk" ? "Генплан містечка Polish Hill" : "Polish Hill master plan"}
  >
    {/* Background */}
    <rect width={svgW} height={svgH} rx="16" fill="var(--ph-bg)" />

    {/* Road */}
    <rect x={PAD - 10} y={PAD + ROW_H + 10} width={svgW - PAD * 2 + 20} height={ROW_GAP - 20} rx="6" fill="var(--ph-bg-alt)" stroke="var(--ph-border-strong)" stroke-width="1" stroke-dasharray="6 4" />
    <text x={svgW / 2} y={PAD + ROW_H + ROW_GAP / 2 + 4} text-anchor="middle" fill="var(--ph-ink-muted)" font-size="11" font-family="var(--font-body)">
      {locale === "uk" ? "Внутрішня дорога" : "Internal road"}
    </text>

    {/* Phase I label */}
    <text x={PAD} y={PAD - 10} fill="var(--ph-ink-soft)" font-size="13" font-weight="600" font-family="var(--font-body)">
      {locale === "uk" ? "I ЧЕРГА" : "PHASE I"}
    </text>

    {/* Phase I lots */}
    {phase1.map((lot, i) => {
      const x = PAD + i * (COL_W + COL_GAP);
      const y = PAD;
      return (
        <a href={lot.status !== "sold" ? `/lots/${lot.id}` : undefined} class="group">
          <rect
            x={x} y={y} width={COL_W} height={ROW_H} rx="8"
            fill={lotFill(lot.status)}
            stroke={lotColor(lot.status)}
            stroke-width="2"
            class="transition-all duration-200 hover:brightness-95"
          />
          {/* Number */}
          <text x={x + COL_W / 2} y={y + 35} text-anchor="middle" fill={lotColor(lot.status)} font-size="22" font-weight="700" font-family="var(--font-display)">
            #{lot.number}
          </text>
          {/* Area */}
          <text x={x + COL_W / 2} y={y + 58} text-anchor="middle" fill="var(--ph-ink-muted)" font-size="10" font-family="var(--font-body)">
            {lot.area} м²
          </text>
          {/* Status */}
          <text x={x + COL_W / 2} y={y + ROW_H - 18} text-anchor="middle" fill={lotColor(lot.status)} font-size="10" font-weight="600" font-family="var(--font-body)">
            {locale === "uk" ? statusLabelUk(lot.status) : lot.status}
          </text>
          {/* Price (if not sold) */}
          {lot.status !== "sold" && (
            <text x={x + COL_W / 2} y={y + ROW_H - 35} text-anchor="middle" fill="var(--ph-ink)" font-size="9" font-family="var(--font-mono)">
              {formatPrice(lot.totalPrice)}
            </text>
          )}
        </a>
      );
    })}

    {/* Phase II label */}
    <text x={PAD} y={PAD + ROW_H + ROW_GAP + 2} fill="var(--ph-ink-soft)" font-size="13" font-weight="600" font-family="var(--font-body)">
      {locale === "uk" ? "II ЧЕРГА" : "PHASE II"}
    </text>

    {/* Phase II lots */}
    {phase2.map((lot, i) => {
      const x = PAD + i * (COL_W + COL_GAP);
      const y = PAD + ROW_H + ROW_GAP + 12;
      return (
        <a href={lot.status !== "sold" ? `/lots/${lot.id}` : undefined} class="group">
          <rect
            x={x} y={y} width={COL_W} height={ROW_H} rx="8"
            fill={lotFill(lot.status)}
            stroke={lotColor(lot.status)}
            stroke-width="2"
            class="transition-all duration-200 hover:brightness-95"
          />
          <text x={x + COL_W / 2} y={y + 35} text-anchor="middle" fill={lotColor(lot.status)} font-size="22" font-weight="700" font-family="var(--font-display)">
            #{lot.number}
          </text>
          <text x={x + COL_W / 2} y={y + 58} text-anchor="middle" fill="var(--ph-ink-muted)" font-size="10" font-family="var(--font-body)">
            {lot.area} м²
          </text>
          {lot.status !== "sold" && (
            <text x={x + COL_W / 2} y={y + ROW_H - 35} text-anchor="middle" fill="var(--ph-ink)" font-size="9" font-family="var(--font-mono)">
              {formatPrice(lot.totalPrice)}
            </text>
          )}
          <text x={x + COL_W / 2} y={y + ROW_H - 18} text-anchor="middle" fill={lotColor(lot.status)} font-size="10" font-weight="600" font-family="var(--font-body)">
            {locale === "uk" ? statusLabelUk(lot.status) : lot.status}
          </text>
        </a>
      );
    })}

    {/* Legend */}
    {[
      { color: "#4a7c59", fill: "#e8f5ec", label: locale === "uk" ? "Вільний" : "Available" },
      { color: "#c8924a", fill: "#fef3e0", label: locale === "uk" ? "Резерв" : "Reserved" },
      { color: "#c4c4c0", fill: "#f0efed", label: locale === "uk" ? "Продано" : "Sold" },
    ].map(({ color, fill, label }, i) => {
      const lx = PAD + i * 120;
      const ly = svgH - 30;
      return (
        <g>
          <rect x={lx} y={ly} width="16" height="16" rx="3" fill={fill} stroke={color} stroke-width="1.5" />
          <text x={lx + 22} y={ly + 12} fill="var(--ph-ink-soft)" font-size="11" font-family="var(--font-body)">
            {label}
          </text>
        </g>
      );
    })}
  </svg>
</div>
