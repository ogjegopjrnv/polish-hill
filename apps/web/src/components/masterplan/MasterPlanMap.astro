---
import { lots, formatPrice, statusLabelUk } from "@data/lots";
import type { Locale } from "@lib/i18n/translations";

const locale = (Astro.currentLocale ?? "uk") as Locale;

// Phase I: 12 cottages (2 rows of 6)
// Phase II: 5 cottages (1 row)
const COL_W = 90;
const COL_GAP = 10;
const ROW_H = 120;
const ROW_GAP = 50;
const PAD = 40;

const phase1 = lots.filter((l) => l.phase === 1);
const phase2 = lots.filter((l) => l.phase === 2);

// Phase I in 2 rows of 6
const phase1Row1 = phase1.slice(0, 6);
const phase1Row2 = phase1.slice(6, 12);

const maxCols = Math.max(phase1Row1.length, phase2.length);
const svgW = PAD * 2 + maxCols * COL_W + (maxCols - 1) * COL_GAP;
const svgH = PAD * 2 + 3 * ROW_H + 2 * ROW_GAP + 110; // 3 rows + labels + extra spacing

function lotColor(status: string) {
  return {
    available: "#4a7c59",
    reserved: "#c8924a",
    sold: "#c4c4c0",
  }[status] ?? "#c4c4c0";
}

function lotFill(status: string) {
  return {
    available: "#e8f5ec",
    reserved: "#fef3e0",
    sold: "#f0efed",
  }[status] ?? "#f0efed";
}
---

<div class="rounded-[var(--ph-radius-2xl)] border border-[var(--ph-border)] bg-[var(--ph-surface)] p-4 md:p-8">
  <div class="md:hidden">
    <p class="text-[0.6875rem] font-semibold uppercase tracking-[0.08em] text-[var(--ph-ink-soft)]">
      {locale === "uk" ? "I черга (12 котеджів)" : "Phase I (12 cottages)"}
    </p>
    <div class="mt-3 grid grid-cols-3 gap-2">
      {phase1.map((lot) => (
        <button
          type="button"
          data-lot-id={lot.id}
          class="min-h-[4.75rem] rounded-[var(--ph-radius-md)] border-2 p-2 text-center transition-transform active:scale-[0.98]"
          style={`background:${lotFill(lot.status)};border-color:${lotColor(lot.status)};`}
        >
          <span class="block text-base font-bold" style={`color:${lotColor(lot.status)};font-family:var(--font-display);`}>
            #{lot.number}
          </span>
          <span class="mt-1 block text-[0.6875rem] leading-tight text-[var(--ph-ink-muted)]">
            ~{lot.area} м²
          </span>
          <span class="mt-2 block text-[0.6875rem] font-semibold leading-tight" style={`color:${lotColor(lot.status)};`}>
            {locale === "uk" ? statusLabelUk(lot.status) : lot.status}
          </span>
        </button>
      ))}
    </div>

    <div class="my-4 rounded-[var(--ph-radius-md)] border border-dashed border-[var(--ph-border-strong)] bg-[var(--ph-bg-alt)] py-2 text-center text-[0.75rem] text-[var(--ph-ink-muted)]">
      {locale === "uk" ? "Внутрішня дорога" : "Internal road"}
    </div>

    <p class="text-[0.6875rem] font-semibold uppercase tracking-[0.08em] text-[var(--ph-ink)]">
      {locale === "uk" ? "II черга (5 таунхаусів) — старт продажів" : "Phase II (5 townhouses) — sales open"}
    </p>
    <div class="mt-3 grid grid-cols-2 gap-2">
      {phase2.map((lot) => (
        <button
          type="button"
          data-lot-id={lot.id}
          class="min-h-[6.75rem] rounded-[var(--ph-radius-md)] border-2 p-3 text-center transition-transform active:scale-[0.98]"
          style={`background:${lotFill(lot.status)};border-color:${lotColor(lot.status)};`}
        >
          <span class="block text-2xl font-bold" style={`color:${lotColor(lot.status)};font-family:var(--font-display);`}>
            #{lot.number}
          </span>
          <span class="mt-1 block text-[0.75rem] leading-tight text-[var(--ph-ink-muted)]">
            {lot.area} м²
          </span>
          <span class="mt-1 block text-[0.6875rem] leading-tight text-[var(--ph-forest-light)]">
            {locale === "uk" ? "Ділянка:" : "Plot:"} {(lot.landArea / 100).toFixed(2)} сот
          </span>
          {lot.status !== "sold" && (
            <span class="mt-2 block text-[0.6875rem] leading-tight text-[var(--ph-ink)]" style="font-family:var(--font-mono);">
              {formatPrice(lot.totalPrice)}
            </span>
          )}
          <span class="mt-1 block text-[0.75rem] font-semibold leading-tight" style={`color:${lotColor(lot.status)};`}>
            {locale === "uk" ? statusLabelUk(lot.status) : lot.status}
          </span>
        </button>
      ))}
    </div>

    <div class="mt-6 flex flex-wrap gap-x-5 gap-y-2 text-[0.75rem] text-[var(--ph-ink-soft)]">
      {[
        { color: "#4a7c59", fill: "#e8f5ec", label: locale === "uk" ? "Вільний" : "Available" },
        { color: "#c8924a", fill: "#fef3e0", label: locale === "uk" ? "Резерв" : "Reserved" },
        { color: "#c4c4c0", fill: "#f0efed", label: locale === "uk" ? "Продано" : "Sold" },
      ].map(({ color, fill, label }) => (
        <span class="inline-flex items-center gap-2">
          <span class="h-3.5 w-3.5 rounded-[4px] border" style={`background:${fill};border-color:${color};`}></span>
          {label}
        </span>
      ))}
    </div>
  </div>

  <svg
    viewBox={`0 0 ${svgW} ${svgH}`}
    class="mx-auto hidden w-full max-w-4xl md:block"
    role="img"
    aria-label={locale === "uk" ? "Генплан містечка Polish Hill" : "Polish Hill master plan"}
  >
    {/* Background */}
    <rect width={svgW} height={svgH} rx="16" fill="var(--ph-bg)" />

    {/* Phase I label */}
    <text x={PAD} y={PAD - 10} fill="var(--ph-ink-soft)" font-size="13" font-weight="600" font-family="var(--font-body)">
      {locale === "uk" ? "I ЧЕРГА (12 котеджів)" : "PHASE I (12 cottages)"}
    </text>

    {/* Phase I Row 1 (lots 1-6) */}
    {phase1Row1.map((lot, i) => {
      const x = PAD + i * (COL_W + COL_GAP);
      const y = PAD;
      return (
        <g class="group cursor-pointer" data-lot-id={lot.id}>
          <rect
            x={x} y={y} width={COL_W} height={ROW_H} rx="8"
            fill={lotFill(lot.status)}
            stroke={lotColor(lot.status)}
            stroke-width="2"
            class="transition-all duration-200 group-hover:brightness-95"
          />
          <text x={x + COL_W / 2} y={y + 30} text-anchor="middle" fill={lotColor(lot.status)} font-size="20" font-weight="700" font-family="var(--font-display)">
            #{lot.number}
          </text>
          <text x={x + COL_W / 2} y={y + 50} text-anchor="middle" fill="var(--ph-ink-muted)" font-size="9" font-family="var(--font-body)">
            ~{lot.area} м²
          </text>
          <text x={x + COL_W / 2} y={y + ROW_H - 15} text-anchor="middle" fill={lotColor(lot.status)} font-size="9" font-weight="600" font-family="var(--font-body)">
            {locale === "uk" ? statusLabelUk(lot.status) : lot.status}
          </text>
          {lot.status !== "sold" && (
            <text x={x + COL_W / 2} y={y + ROW_H - 32} text-anchor="middle" fill="var(--ph-ink)" font-size="8" font-family="var(--font-mono)">
              {formatPrice(lot.totalPrice)}
            </text>
          )}
        </g>
      );
    })}

    {/* Phase I Row 2 (lots 7-12) */}
    {phase1Row2.map((lot, i) => {
      const x = PAD + i * (COL_W + COL_GAP);
      const y = PAD + ROW_H + 15;
      return (
        <g class="group cursor-pointer" data-lot-id={lot.id}>
          <rect
            x={x} y={y} width={COL_W} height={ROW_H} rx="8"
            fill={lotFill(lot.status)}
            stroke={lotColor(lot.status)}
            stroke-width="2"
            class="transition-all duration-200 group-hover:brightness-95"
          />
          <text x={x + COL_W / 2} y={y + 30} text-anchor="middle" fill={lotColor(lot.status)} font-size="20" font-weight="700" font-family="var(--font-display)">
            #{lot.number}
          </text>
          <text x={x + COL_W / 2} y={y + 50} text-anchor="middle" fill="var(--ph-ink-muted)" font-size="9" font-family="var(--font-body)">
            ~{lot.area} м²
          </text>
          <text x={x + COL_W / 2} y={y + ROW_H - 15} text-anchor="middle" fill={lotColor(lot.status)} font-size="9" font-weight="600" font-family="var(--font-body)">
            {locale === "uk" ? statusLabelUk(lot.status) : lot.status}
          </text>
          {lot.status !== "sold" && (
            <text x={x + COL_W / 2} y={y + ROW_H - 32} text-anchor="middle" fill="var(--ph-ink)" font-size="8" font-family="var(--font-mono)">
              {formatPrice(lot.totalPrice)}
            </text>
          )}
        </g>
      );
    })}

    {/* Road */}
    <rect
      x={PAD - 10}
      y={PAD + 2 * ROW_H + 25}
      width={svgW - PAD * 2 + 20}
      height={ROW_GAP - 10}
      rx="6"
      fill="var(--ph-bg-alt)"
      stroke="var(--ph-border-strong)"
      stroke-width="1"
      stroke-dasharray="6 4"
    />
    <text x={svgW / 2} y={PAD + 2 * ROW_H + 25 + (ROW_GAP - 10) / 2 + 4} text-anchor="middle" fill="var(--ph-ink-muted)" font-size="10" font-family="var(--font-body)">
      {locale === "uk" ? "Внутрішня дорога" : "Internal road"}
    </text>

    {/* Phase II label */}
    <text x={PAD} y={PAD + 2 * ROW_H + ROW_GAP + 45} fill="var(--ph-ink-soft)" font-size="13" font-weight="600" font-family="var(--font-body)">
      {locale === "uk" ? "II ЧЕРГА (5 таунхаусів) — СТАРТ ПРОДАЖІВ" : "PHASE II (5 townhouses) — SALES OPEN"}
    </text>

    {/* Phase II lots */}
    {phase2.map((lot, i) => {
      const x = PAD + i * (COL_W + COL_GAP);
      const y = PAD + 2 * ROW_H + ROW_GAP + 60;
      return (
        <g class="group cursor-pointer" data-lot-id={lot.id}>
          <rect
            x={x} y={y} width={COL_W} height={ROW_H} rx="8"
            fill={lotFill(lot.status)}
            stroke={lotColor(lot.status)}
            stroke-width="2.5"
            class="transition-all duration-200 group-hover:brightness-95"
          />
          <text x={x + COL_W / 2} y={y + 30} text-anchor="middle" fill={lotColor(lot.status)} font-size="20" font-weight="700" font-family="var(--font-display)">
            #{lot.number}
          </text>
          <text x={x + COL_W / 2} y={y + 48} text-anchor="middle" fill="var(--ph-ink-muted)" font-size="9" font-family="var(--font-body)">
            {lot.area} м²
          </text>
          <text x={x + COL_W / 2} y={y + 62} text-anchor="middle" fill="var(--ph-forest-light)" font-size="8" font-family="var(--font-body)">
            {locale === "uk" ? "Ділянка:" : "Plot:"} {(lot.landArea / 100).toFixed(2)} сот
          </text>
          {lot.status !== "sold" && (
            <text x={x + COL_W / 2} y={y + ROW_H - 32} text-anchor="middle" fill="var(--ph-ink)" font-size="8" font-family="var(--font-mono)">
              {formatPrice(lot.totalPrice)}
            </text>
          )}
          <text x={x + COL_W / 2} y={y + ROW_H - 15} text-anchor="middle" fill={lotColor(lot.status)} font-size="9" font-weight="600" font-family="var(--font-body)">
            {locale === "uk" ? statusLabelUk(lot.status) : lot.status}
          </text>
        </g>
      );
    })}

    {/* Legend */}
    {[
      { color: "#4a7c59", fill: "#e8f5ec", label: locale === "uk" ? "Вільний" : "Available" },
      { color: "#c8924a", fill: "#fef3e0", label: locale === "uk" ? "Резерв" : "Reserved" },
      { color: "#c4c4c0", fill: "#f0efed", label: locale === "uk" ? "Продано" : "Sold" },
    ].map(({ color, fill, label }, i) => {
      const lx = PAD + i * 110;
      const ly = svgH - 30;
      return (
        <g>
          <rect x={lx} y={ly} width="14" height="14" rx="3" fill={fill} stroke={color} stroke-width="1.5" />
          <text x={lx + 20} y={ly + 11} fill="var(--ph-ink-soft)" font-size="10" font-family="var(--font-body)">
            {label}
          </text>
        </g>
      );
    })}
  </svg>
</div>

<script>
  // Click handler for cottage selection
  document.querySelectorAll('[data-lot-id]').forEach(el => {
    el.addEventListener('click', () => {
      const lotId = el.getAttribute('data-lot-id');
      if (lotId) {
        window.dispatchEvent(new CustomEvent('open-cottage-modal', { detail: { lotId } }));
      }
    });
  });
</script>
