---
import type { Locale } from "@lib/i18n/translations";

const locale = (Astro.currentLocale ?? "uk") as Locale;
---

<section id="about" class="section bg-[var(--ph-surface)]">
  <div class="container-ph">
    <div class="grid grid-cols-1 items-center gap-16 lg:grid-cols-2">
      <!-- Image -->
      <div class="reveal">
        <div class="overflow-hidden rounded-[var(--ph-radius-2xl)] shadow-[var(--ph-shadow-lg)]">
          <img
            src="/images/client/2nd1x1.jpg"
            alt={locale === "uk" ? "Polish Hill II — таунхауси другої черги" : "Polish Hill Phase II townhouses"}
            class="aspect-square w-full object-cover"
            loading="lazy"
            decoding="async"
          />
        </div>
      </div>

      <!-- Text -->
      <div class="reveal" style="transition-delay: 100ms;">
        <span class="text-[0.75rem] font-semibold uppercase tracking-[0.15em] text-[var(--ph-forest)]">
          {locale === "uk" ? "Про проєкт" : "About"}
        </span>
        <h2 class="mt-3">
          {locale === "uk" ? "Polish Hill II — ваш таунхаус серед природи" : "Polish Hill II — your townhouse in nature"}
        </h2>
        <p class="mt-4 text-[var(--ph-ink-soft)]">
          {locale === "uk"
            ? "ЖК «Польський куточок» — котеджне містечко комфорт-класу в Оболонському районі Києва. Проєкт розташований на території КДТ «Чорнобилець», урочище «Наталка», 9 лінія."
            : "Polish Hill is a comfort-class cottage community in Obolon district, Kyiv. Located in KDT Chornobylec, Natalka tract, line 9."}
        </p>
        <p class="mt-3 text-[var(--ph-ink-soft)]">
          {locale === "uk"
            ? "I черга (12 котеджів) — повністю завершена і заселена. II черга (5 таунхаусів) — активний продаж. Кожен таунхаус — 170 м² на 3 поверхи з індивідуальною ділянкою від 1.2 до 2.94 соток."
            : "Phase I (12 cottages) — fully completed. Phase II (5 townhouses) — active sales. Each townhouse is 170 m² on 3 floors with individual plot from 1.2 to 2.94 sotka."}
        </p>

        <div class="mt-8 grid grid-cols-2 gap-4">
          {[
            { value: "2019", label: locale === "uk" ? "Рік заснування" : "Founded" },
            { value: "17", label: locale === "uk" ? "Котеджів у проєкті" : "Cottages total" },
            { value: "170 м²", label: locale === "uk" ? "Площа таунхауса" : "Townhouse area" },
            { value: "8 га", label: locale === "uk" ? "Територія" : "Territory" },
          ].map(({ value, label }) => (
            <div class="rounded-[var(--ph-radius-lg)] border border-[var(--ph-border)] bg-[var(--ph-bg)] p-4 text-center">
              <span class="tabular-nums text-[1.5rem] font-bold text-[var(--ph-forest)]">{value}</span>
              <p class="mt-1 text-[0.6875rem] text-[var(--ph-ink-muted)]">{label}</p>
            </div>
          ))}
        </div>

        {/* Documents */}
        <div class="mt-8">
          <h4 class="text-[0.8125rem] font-semibold text-[var(--ph-ink)]">
            {locale === "uk" ? "Документи" : "Documents"}
          </h4>
          <p class="mt-1 text-[0.8125rem] text-[var(--ph-ink-soft)]">
            {locale === "uk"
              ? "Всі дозвільні документи, кадастровий план та юридичні висновки доступні за запитом."
              : "All permits, cadastral plan and legal opinions available upon request."}
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
