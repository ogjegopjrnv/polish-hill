---
import { Medal } from "lucide-astro";
import PaymentCalculator from "@components/calculator/PaymentCalculator";
import type { Locale } from "@lib/i18n/translations";

const locale = (Astro.currentLocale ?? "uk") as Locale;

const steps = locale === "uk"
  ? [
    { num: "01", title: "Обрати котедж", text: "Перегляньте каталог або відвідайте містечко." },
    { num: "02", title: "Підписати договір", text: "Фіксація ціни в доларах." },
    { num: "03", title: "Перший внесок", text: "Від 30%. Решта — безпроцентна розстрочка." },
    { num: "04", title: "Щомісячні платежі", text: "Рівними частинами 1.5 року (18 міс). Без банків." },
  ]
  : [
    { num: "01", title: "Choose", text: "Browse the catalog or visit." },
    { num: "02", title: "Contract", text: "Price fixed in USD." },
    { num: "03", title: "Down payment", text: "From 30%. Rest interest-free." },
    { num: "04", title: "Monthly", text: "Equal parts 1.5 years (18 mo). No banks." },
  ];
---

<section id="finance" class="section bg-[var(--ph-bg)]">
  <div class="container-ph">
    <div class="reveal mx-auto max-w-2xl text-center">
      <span class="text-[0.75rem] font-semibold uppercase tracking-[0.15em] text-[var(--ph-forest)]">
        {locale === "uk" ? "Фінанси" : "Finance"}
      </span>
      <h2 class="mt-3">
        {locale === "uk" ? "0% розстрочка на 1.5 року" : "0% installment for 1.5 years"}
      </h2>
    </div>

    <div class="reveal mt-12 grid grid-cols-2 gap-4 lg:grid-cols-4">
      {steps.map(({ num, title, text }) => (
        <div class="rounded-[var(--ph-radius-xl)] border border-[var(--ph-border)] bg-[var(--ph-surface)] p-5">
          <span class="tabular-nums text-[2rem] font-bold leading-none tracking-tighter text-[var(--ph-forest)]/20" style="font-family: var(--font-mono);">
            {num}
          </span>
          <h3 class="mt-2 text-[0.9375rem]">{title}</h3>
          <p class="mt-1.5 text-[0.8125rem] leading-relaxed text-[var(--ph-ink-soft)]">{text}</p>
        </div>
      ))}
    </div>

    <div class="reveal mt-14 mx-auto max-w-3xl">
      <PaymentCalculator client:visible locale={locale} />
    </div>

    <div class="reveal mt-12 mx-auto max-w-2xl rounded-[var(--ph-radius-2xl)] border-2 border-[var(--ph-forest)]/20 bg-[var(--ph-forest)]/[0.03] p-8 text-center">
      <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-full bg-amber-100 text-amber-600">
        <Medal size={24} strokeWidth={1.5} />
      </div>
      <h3 class="mt-4">
        {locale === "uk" ? "Спеціальні умови для ЗСУ" : "Special terms for military"}
      </h3>
      <p class="mt-2 text-[0.875rem] text-[var(--ph-ink-soft)]">
        {locale === "uk"
          ? "Знижка та гнучкий графік оплати для військовослужбовців та їх сімей."
          : "Discount and flexible payment for military personnel and their families."}
      </p>
      <a href="tel:+380674406070" class="mt-4 inline-block text-lg font-semibold text-[var(--ph-forest)]">
        +380 67 440 60 70
      </a>
    </div>
  </div>
</section>
