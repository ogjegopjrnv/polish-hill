---
import { lots, formatPrice } from "@data/lots";
import type { Locale } from "@lib/i18n/translations";

const locale = (Astro.currentLocale ?? "uk") as Locale;

const phase2 = lots.filter((l) => l.phase === 2);
const availableCount = lots.filter((l) => l.status === "available").length;

const statusColors: Record<string, string> = {
  available: "bg-emerald-50 text-emerald-700 border-emerald-200",
  reserved: "bg-amber-50 text-amber-700 border-amber-200",
  sold: "bg-neutral-100 text-neutral-500 border-neutral-200",
};

function statusLabel(status: string) {
  return locale === "uk"
    ? { available: "Вільний", reserved: "Резерв", sold: "Продано" }[status]
    : { available: "Available", reserved: "Reserved", sold: "Sold" }[status];
}
---

<section id="cottages" class="section bg-[var(--ph-surface)]">
  <div class="container-ph">
    <div class="reveal mx-auto max-w-2xl text-center">
      <span class="text-[0.75rem] font-semibold uppercase tracking-[0.15em] text-[var(--ph-forest)]">
        {locale === "uk" ? "II черга — продаж відкрито" : "Phase II — now selling"}
      </span>
      <h2 class="mt-3">
        {locale === "uk" ? "Оберіть свій таунхаус" : "Choose your townhouse"}
      </h2>
      <p class="mt-4 text-[var(--ph-ink-soft)]">
        {locale === "uk"
          ? `${availableCount} таунхаусів вільні. Площа 170 м², 3 поверхи, від $1 000/м².`
          : `${availableCount} townhouses available. 170 m², 3 floors, from $1,000/m².`}
      </p>
    </div>

    {/* Compact lot cards grid */}
    <div class="mt-14 grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-4">
      {phase2.map((lot, idx) => (
        <div
          class:list={[
            "reveal group relative overflow-hidden rounded-[var(--ph-radius-xl)] border bg-[var(--ph-bg)] transition-all duration-[var(--ph-duration-ui)]",
            lot.status !== "sold"
              ? "border-[var(--ph-border)] hover:border-[var(--ph-forest)]/20 hover:shadow-[var(--ph-shadow-lg)] cursor-pointer"
              : "border-[var(--ph-border)] opacity-70",
          ]}
          style={`transition-delay: ${idx * 60}ms;`}
          data-cottage-trigger={lot.status !== "sold" ? lot.id : undefined}
          role={lot.status !== "sold" ? "button" : undefined}
          tabindex={lot.status !== "sold" ? "0" : undefined}
        >
          {/* Image */}
          <div class="relative aspect-[16/10] overflow-hidden">
            <img
              src={lot.image}
              alt={`Таунхаус №${lot.number}`}
              class:list={[
                "h-full w-full object-cover transition-transform duration-700 ease-[var(--ph-ease)]",
                lot.status === "available" && "group-hover:scale-105",
              ]}
              loading="lazy"
              decoding="async"
            />
            <div class="absolute top-2.5 left-2.5">
              <span class:list={["inline-flex items-center gap-1 rounded-full border px-2.5 py-0.5 text-[0.625rem] font-semibold", statusColors[lot.status]]}>
                <span class:list={[
                  "h-1.5 w-1.5 rounded-full",
                  lot.status === "available" && "bg-emerald-500",
                  lot.status === "reserved" && "bg-amber-500",
                  lot.status === "sold" && "bg-neutral-400",
                ]}></span>
                {statusLabel(lot.status)}
              </span>
            </div>
          </div>

          {/* Info */}
          <div class="p-4">
            <div class="flex items-start justify-between">
              <div>
                <h3 class="text-base leading-tight">
                  №{lot.number}
                </h3>
                <p class="mt-0.5 text-[0.75rem] text-[var(--ph-ink-muted)]">
                  {lot.area} м² · {lot.floors} пов. · Діл. {(lot.landArea / 100).toFixed(2)} сот
                </p>
              </div>
              {lot.status !== "sold" && (
                <span class="tabular-nums text-base font-bold text-[var(--ph-forest)]">
                  {formatPrice(lot.totalPrice)}
                </span>
              )}
            </div>

            {lot.features.length > 0 && (
              <div class="mt-3 flex flex-wrap gap-1">
                {lot.features.slice(0, 3).map((f) => (
                  <span class="rounded-[var(--ph-radius-sm)] bg-[var(--ph-surface)] px-2 py-0.5 text-[0.625rem] text-[var(--ph-ink-muted)]">
                    {f}
                  </span>
                ))}
              </div>
            )}
          </div>
        </div>
      ))}
    </div>

    {/* Floor plan */}
    <div class="reveal mt-14 rounded-[var(--ph-radius-2xl)] border border-[var(--ph-border)] bg-[var(--ph-bg)] p-6 md:p-10">
      <div class="text-center">
        <h3 class="text-lg">
          {locale === "uk" ? "Планування таунхаусу" : "Townhouse floor plan"}
        </h3>
        <p class="mt-2 text-[0.8125rem] text-[var(--ph-ink-soft)]">
          {locale === "uk"
            ? "170 м² на 3 поверхи — продумане планування для комфортного життя."
            : "170 m² across 3 floors — thoughtful layout for comfortable living."}
        </p>
      </div>

      {/* Desktop — full SVG */}
      <div class="mt-8 hidden md:block">
        <img
          src="/images/client/polish-hill-plan.svg"
          alt={locale === "uk" ? "Планування таунхаусу Polish Hill — 3 поверхи" : "Polish Hill townhouse floor plan — 3 floors"}
          class="mx-auto w-full max-w-5xl cursor-zoom-in"
          loading="lazy"
          decoding="async"
          data-plan-zoom
        />
      </div>

      {/* Mobile — floors stacked vertically */}
      <div class="mt-6 flex flex-col gap-6 md:hidden">
        {([
          { label: "1-й поверх", src: "/images/client/polish-hill-floor-1.svg" },
          { label: "2-й поверх", src: "/images/client/polish-hill-floor-2.svg" },
          { label: "3-й поверх", src: "/images/client/polish-hill-floor-3.svg" },
        ] as const).map(({ label, src }) => (
          <div>
            <p class="mb-2 text-center text-[0.8125rem] font-semibold text-[var(--ph-forest)]">
              {label}
            </p>
            <img
              src={src}
              alt={label}
              class="w-full rounded-[var(--ph-radius-lg)] cursor-zoom-in"
              loading="lazy"
              decoding="async"
              data-plan-zoom
            />
          </div>
        ))}
      </div>

      <p class="mt-4 text-center text-[0.6875rem] text-[var(--ph-ink-muted)]">
        {locale === "uk" ? "Натисніть для збільшення" : "Tap to zoom"}
      </p>
    </div>

    {/* Zoom lightbox */}
    <div
      id="plan-lightbox"
      class="fixed inset-0 z-[200] hidden bg-black/90 backdrop-blur-sm"
      aria-hidden="true"
    >
      <button
        id="plan-lightbox-close"
        class="absolute top-4 right-4 z-10 flex h-10 w-10 items-center justify-center rounded-full bg-white/15 text-white backdrop-blur-sm transition-colors hover:bg-white/25"
        aria-label="Закрити"
      >
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
      <div id="plan-lightbox-viewport" class="flex h-full w-full items-center justify-center overflow-hidden touch-none">
        <img id="plan-lightbox-img" src="" alt="" class="max-h-none max-w-none select-none" draggable="false" />
      </div>
    </div>

    <script>
      {
        const lb = document.getElementById('plan-lightbox')!;
        const vp = document.getElementById('plan-lightbox-viewport')!;
        const img = document.getElementById('plan-lightbox-img') as HTMLImageElement;
        const closeBtn = document.getElementById('plan-lightbox-close')!;

        let scale = 1;
        let tx = 0;
        let ty = 0;
        let startDist = 0;
        let startScale = 1;
        let dragging = false;
        let dragStart = { x: 0, y: 0 };
        let dragTxStart = 0;
        let dragTyStart = 0;

        const MIN_SCALE = 0.5;
        const MAX_SCALE = 5;

        function applyTransform() {
          img.style.transform = `translate(${tx}px, ${ty}px) scale(${scale})`;
        }

        function open(src: string, alt: string) {
          img.src = src;
          img.alt = alt;
          scale = 1; tx = 0; ty = 0;
          applyTransform();
          lb.classList.remove('hidden');
          lb.setAttribute('aria-hidden', 'false');
          document.body.style.overflow = 'hidden';
        }

        function close() {
          lb.classList.add('hidden');
          lb.setAttribute('aria-hidden', 'true');
          document.body.style.overflow = '';
        }

        // Open triggers
        document.querySelectorAll<HTMLImageElement>('[data-plan-zoom]').forEach(el => {
          el.addEventListener('click', () => open(el.src, el.alt));
        });

        // Close
        closeBtn.addEventListener('click', close);
        document.addEventListener('keydown', e => {
          if (e.key === 'Escape' && !lb.classList.contains('hidden')) close();
        });
        vp.addEventListener('click', e => { if (e.target === vp) close(); });

        // Double-tap / double-click to toggle zoom
        let lastTap = 0;
        vp.addEventListener('click', e => {
          if (e.target !== img) return;
          const now = Date.now();
          if (now - lastTap < 300) {
            if (scale > 1.2) {
              scale = 1; tx = 0; ty = 0;
            } else {
              const rect = vp.getBoundingClientRect();
              const cx = e.clientX - rect.left - rect.width / 2;
              const cy = e.clientY - rect.top - rect.height / 2;
              scale = 3;
              tx = -cx * 2;
              ty = -cy * 2;
            }
            applyTransform();
          }
          lastTap = now;
        });

        // Mouse wheel zoom
        vp.addEventListener('wheel', e => {
          e.preventDefault();
          const delta = e.deltaY > 0 ? 0.9 : 1.1;
          const newScale = Math.min(MAX_SCALE, Math.max(MIN_SCALE, scale * delta));
          const rect = vp.getBoundingClientRect();
          const cx = e.clientX - rect.left - rect.width / 2;
          const cy = e.clientY - rect.top - rect.height / 2;
          tx = cx - (cx - tx) * (newScale / scale);
          ty = cy - (cy - ty) * (newScale / scale);
          scale = newScale;
          applyTransform();
        }, { passive: false });

        // Touch: pinch-to-zoom + pan
        vp.addEventListener('touchstart', e => {
          if (e.touches.length === 2) {
            const dx = e.touches[0].clientX - e.touches[1].clientX;
            const dy = e.touches[0].clientY - e.touches[1].clientY;
            startDist = Math.hypot(dx, dy);
            startScale = scale;
          } else if (e.touches.length === 1 && scale > 1) {
            dragging = true;
            dragStart = { x: e.touches[0].clientX, y: e.touches[0].clientY };
            dragTxStart = tx;
            dragTyStart = ty;
          }
        }, { passive: true });

        vp.addEventListener('touchmove', e => {
          if (e.touches.length === 2) {
            e.preventDefault();
            const dx = e.touches[0].clientX - e.touches[1].clientX;
            const dy = e.touches[0].clientY - e.touches[1].clientY;
            const dist = Math.hypot(dx, dy);
            scale = Math.min(MAX_SCALE, Math.max(MIN_SCALE, startScale * (dist / startDist)));
            applyTransform();
          } else if (e.touches.length === 1 && dragging) {
            e.preventDefault();
            tx = dragTxStart + (e.touches[0].clientX - dragStart.x);
            ty = dragTyStart + (e.touches[0].clientY - dragStart.y);
            applyTransform();
          }
        }, { passive: false });

        vp.addEventListener('touchend', () => { dragging = false; }, { passive: true });

        // Mouse drag
        vp.addEventListener('mousedown', e => {
          if (scale <= 1 || e.target !== img) return;
          dragging = true;
          dragStart = { x: e.clientX, y: e.clientY };
          dragTxStart = tx;
          dragTyStart = ty;
          img.style.cursor = 'grabbing';
        });
        window.addEventListener('mousemove', e => {
          if (!dragging) return;
          tx = dragTxStart + (e.clientX - dragStart.x);
          ty = dragTyStart + (e.clientY - dragStart.y);
          applyTransform();
        });
        window.addEventListener('mouseup', () => {
          dragging = false;
          if (scale > 1) img.style.cursor = 'grab';
        });
      }
    </script>

    {/* Phase I summary — compact */}
    <div class="reveal mt-12 rounded-[var(--ph-radius-xl)] border border-[var(--ph-border)] bg-[var(--ph-bg)] p-6 text-center">
      <p class="text-[0.875rem] text-[var(--ph-ink-soft)]">
        {locale === "uk"
          ? "I черга (12 котеджів) — повністю завершена та продана."
          : "Phase I (12 cottages) — fully completed and sold."}
      </p>
    </div>
  </div>
</section>
